# Optional — without these, the sandbox uses mongodb-memory-server.
MONGODB_URI=
MONGODB_DB_NAME=rr7_rsc_rag

# Better Auth (secret should be ≥32 chars)
BETTER_AUTH_SECRET=replace-with-a-long-random-string-at-least-32
BETTER_AUTH_URL=http://localhost:5173
# Optional comma-separated extras (localhost:* / 127.0.0.1:* are already trusted)
# BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.1.10:5173
