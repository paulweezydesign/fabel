# Copy this file to `.env` and adjust values as needed.
# `.env` is gitignored — never commit real secrets.

# Port the standalone API server listens on.
PORT=3000

# --- AI provider (optional / forward-looking) ---
# The AI client is stubbed by default, so these are NOT required to run the
# app or tests. Provide them once a real provider is wired up.

# API key for the OpenAI-compatible provider. Leave blank to use the stub.
OPENAI_API_KEY=

# Base URL for the OpenAI-compatible API.
OPENAI_BASE_URL=https://api.openai.com/v1

# Default model identifier used for agent completions.
OPENAI_MODEL=gpt-4o-mini
