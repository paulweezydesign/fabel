# -----------------------------------------------------------------------------
# AI provider (server-side only — never exposed to the browser)
# -----------------------------------------------------------------------------

# Active provider: nim (default) | openai | stub
AI_PROVIDER=nim

# Persistence for workflow runs + artifacts: sqlite (default) | file | memory
# sqlite writes a single DB at .data/fabel.db (or FABEL_SQLITE_PATH).
# file uses .artifacts/ + .workflow-runs/ (legacy JSON). memory is ephemeral.
FABEL_PERSISTENCE=sqlite
# FABEL_SQLITE_PATH=.data/fabel.db

# -----------------------------------------------------------------------------
# Single-tenant auth (optional for local/CI; recommended for any shared host)
# When FABEL_AUTH_PASSWORD is unset, the dashboard and APIs stay open.
# -----------------------------------------------------------------------------

# Shared operator password. Setting this enables login for `/` and `/api/**`.
# FABEL_AUTH_PASSWORD=

# Cookie signing secret (defaults to the password if unset — set a distinct value in prod).
# FABEL_AUTH_SECRET=

# Session lifetime in seconds (default: 604800 = 7 days).
# FABEL_AUTH_MAX_AGE_SECONDS=604800

# -----------------------------------------------------------------------------
# NVIDIA NIM (OpenAI-compatible) — https://build.nvidia.com
# Required when running agents against live models (not needed for CI/tests).
# -----------------------------------------------------------------------------

# API key from https://build.nvidia.com — use .env.local, never commit real keys.
NVIDIA_NIM_API_KEY=nvapi-your-key-here

# Chat model id (default: nvidia/nemotron-3-ultra-550b-a55b).
NVIDIA_NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# OpenAI-compatible base URL for NIM chat completions.
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# -----------------------------------------------------------------------------
# OpenAI API — https://platform.openai.com
# Required when AI_PROVIDER=openai.
# -----------------------------------------------------------------------------

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
