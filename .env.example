# -----------------------------------------------------------------------------
# AI provider (server-side only — never exposed to the browser)
# -----------------------------------------------------------------------------

# Active provider: nim (default) | openai | stub
AI_PROVIDER=nim

# Persistence for workflow runs + artifacts: file (default) | memory
# file writes under .artifacts/ and .workflow-runs/ (gitignored) so past runs
# survive `npm run dev` restarts. Use memory for ephemeral throwaway sessions.
FABEL_PERSISTENCE=file

# -----------------------------------------------------------------------------
# NVIDIA NIM (OpenAI-compatible) — https://build.nvidia.com
# Required when running agents against live models (not needed for CI/tests).
# -----------------------------------------------------------------------------

# API key from https://build.nvidia.com — use .env.local, never commit real keys.
NVIDIA_NIM_API_KEY=nvapi-your-key-here

# Chat model id (default: nvidia/nemotron-3-ultra-550b-a55b).
NVIDIA_NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# OpenAI-compatible base URL for NIM chat completions.
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# -----------------------------------------------------------------------------
# OpenAI API — https://platform.openai.com
# Required when AI_PROVIDER=openai.
# -----------------------------------------------------------------------------

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
